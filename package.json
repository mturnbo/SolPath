{
  "name": "solpath",
  "version": "1.0.0",
  "description": "Constant-thrust trajectory planner for the inner and outer solar system",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.solpath.app",
    "productName": "SolPath",
    "files": [
      "index.html",
      "src/**/*",
      "electron/**/*"
    ],
    "directories": {
      "output": "dist"
    },
    "mac": {
      "category": "public.app-category.education",
      "icon": "docs/icon.icns"
    },
    "win": {
      "target": "nsis",
      "icon": "docs/icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "category": "Education"
    }
  },
  "devDependencies": {
    "electron": "^36.0.0",
    "electron-builder": "^25.0.0"
  }
}
